  "splits": {
    "train": {
      "file": "data/processed/finetune_chatml_format.jsonl",
      "num_examples": 20,
      "description": "Training Q&A pairs in ChatML format"
    },
    "retrieval_index": {
      "file": "data/raw/key_verses.csv",
      "num_examples": 17,
      "description": "Annotated verse corpus for RAG retrieval"
    },
    "problem_mapping": {
      "file": "data/processed/problem_verse_mapping.csv",
      "num_examples": 30,
      "description": "Problem keyword to verse mapping index"
    }
  },
  "features": {
    "qa_pairs": {
      "qa_id": {
        "dtype": "string",
        "description": "Unique Q&A pair identifier"
      },
      "category": {
        "dtype": "string",
        "description": "Problem category"
      },
      "user_question": {
        "dtype": "string",
        "description": "Modern life question"
      },
      "krishna_response": {
        "dtype": "string",
        "description": "Response in Krishna's voice with shloka"
      },
      "verse_id": {
        "dtype": "string",
        "description": "Referenced Gita verse ID"
      },
      "language": {
        "dtype": "string",
        "description": "en or hi"
      }
    },
    "key_verses": {
      "verse_id": {
        "dtype": "string",
        "description": "BG_{chapter}_{verse} format"
      },
      "sanskrit_devanagari": {
        "dtype": "string",
        "description": "Original Sanskrit text"
      },
      "transliteration": {
        "dtype": "string",
        "description": "IAST Roman transliteration"
      },
      "translation_english": {
        "dtype": "string",
        "description": "English translation"
      },
      "translation_hindi": {
        "dtype": "string",
        "description": "Hindi translation"
      },
      "modern_question_mapping": {
        "dtype": "string",
        "description": "Modern problems addressed"
      },
      "difficulty_level": {
        "dtype": "string",
        "description": "foundational/intermediate/advanced"
      }
    }
  },
  "statistics": {
    "total_chapters": 18,
    "total_gita_verses": 700,
